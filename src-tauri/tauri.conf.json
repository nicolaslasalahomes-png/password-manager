{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Keyring",
  "version": "0.1.6",
  "identifier": "com.nicolassut.keyring",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Keyring",
        "width": 1100,
        "height": 720,
        "minWidth": 760,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/nicolassut/password-manager/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwMDU1NDNCMjZCMDQ4M0IKUldRN1NMQW1PMVFGY0JoVGJuK24yMlhjQVFsWG13ZVBFRC9GemlDeFd2YlA0djZGaWhVQ0kxK1UK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "shortDescription": "Personal encrypted vault for passwords and API keys",
    "longDescription": "Keyring is a zero-knowledge password and API key vault. Master password never leaves your device.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
