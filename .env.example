# Public client env vars (safe to expose in browser bundle)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only secrets (NEVER commit, NEVER expose to client):
#   SUPABASE_SERVICE_ROLE_KEY  — used in edge functions / server routes only
#   SUPABASE_PAT               — used for management API (CLI / CI), not runtime
